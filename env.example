# ─────────────────────────────────────────────────────────────
#  RAG Q&A Bot — Environment Configuration
#  Copy this file to .env  →  cp .env.example .env
#  NEVER commit .env to Git (.gitignore already excludes it)
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────
# Options: ollama | openai | anthropic
# "ollama" is the default — FREE, runs locally, NO API key needed
LLM_PROVIDER=ollama

# ── Ollama (default — free, local, no sign-up required) ───────
# Install: https://ollama.com/download
# Pull model (one-time): ollama pull llama3.2
# Other good models: mistral, phi3, gemma2, qwen2.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (optional — only needed if LLM_PROVIDER=openai) ───
# OPENAI_API_KEY=sk-...

# ── Anthropic (optional — only needed if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
